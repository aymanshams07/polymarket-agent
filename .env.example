# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket
DATABASE_URL=postgresql+asyncpg://polymarket:polymarket@postgres:5432/polymarket

# ─── Qdrant ─────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

OPENAI_API_KEY=sk-proj-your-key-here  # optional fallback

# ─── News / Search ───────────────────────────────────────────
TAVILY_API_KEY=tvly-your-key-here
NEWSAPI_KEY=your-newsapi-key-here

# ─── Polymarket ──────────────────────────────────────────────
POLYMARKET_API_BASE=https://gamma-api.polymarket.com

# ─── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# BACKEND_CORS_ORIGINS not set — defaults to ["http://localhost:3000"] in config.py
